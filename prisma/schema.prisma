generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              user    @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Account_userId_fkey")

  @@unique([provider, providerAccountId], map: "Account_provider_providerAccountId_key")
  @@index([userId], map: "Account_userId_fkey")
}

model inventory {
  id        String @id
  productId String
  size      String
  colorName String
  stock     Int    @default(5)

  @@unique([productId, size, colorName], map: "Inventory_productId_size_colorName_key")
}

model order {
  id              String   @id
  userId          String?
  items           String
  totalPrice      Float
  status          String   @default("Processing")
  trackingNumber  String?
  shippingAddress String?
  pincode         String?
  paymentMethod   String?
  contactEmail    String?
  contactPhone    String?
  customerName    String?
  createdAt       DateTime @default(now())
  user            user?    @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Order_userId_fkey")

  @@index([userId], map: "Order_userId_fkey")
}

model saveditem {
  id        String   @id
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "SavedItem_userId_fkey")

  @@index([userId], map: "SavedItem_userId_fkey")
}

model session {
  id           String   @id
  sessionToken String   @unique(map: "Session_sessionToken_key")
  userId       String
  expires      DateTime
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Session_userId_fkey")

  @@index([userId], map: "Session_userId_fkey")
}

model user {
  id            String      @id
  name          String?
  email         String?     @unique(map: "User_email_key")
  password      String?
  emailVerified DateTime?
  image         String?
  tier          String      @default("None")
  phone         String?
  address       String?
  apartment     String?
  city          String?
  state         String?
  pincode       String?
  country       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  cardNumber    String?
  points        Int         @default(0)
  referralCode  String?     @unique(map: "User_referralCode_key")
  referredById  String?
  account       account[]
  order         order[]
  saveditem     saveditem[]
  session       session[]
  user          user?       @relation("userTouser", fields: [referredById], references: [id], map: "User_referredById_fkey")
  other_user    user[]      @relation("userTouser")

  @@index([referredById], map: "User_referredById_fkey")
}

model verificationtoken {
  identifier String
  token      String   @unique(map: "VerificationToken_token_key")
  expires    DateTime

  @@unique([identifier, token], map: "VerificationToken_identifier_token_key")
}
