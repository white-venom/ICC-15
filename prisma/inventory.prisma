generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/inventory-client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./inventory.db"
}

model Inventory {
  id        String @id @default(cuid())
  productId String // from products.json (e.g., "white")
  size      String // size label (e.g., "40")
  colorName String // e.g., "Ivory White"
  stock     Int    @default(5)

  @@unique([productId, size, colorName])
}
